  "homepage": "https://iembrace-app.github.io/ideal-adventure-z2qp27p",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc && vite build",
    "build:analyze": "npm run build && echo Build complete! Check dist/bundle-analysis.html for bundle analysis",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rimraf node_modules docs dist .vite",
    "clean:install": "npm run clean && npm install"
  },
  "dependencies": {
    "framer-motion": "^12.19.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^6.0.3",
    "terser": "^5.43.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.1"
  }
